{
  "manifest_version": 3,
  "name": "ZenWork",
  "version": "1.0.0",
  "description": "AI-powered focus and self-tracking companion. ZenWork tracks your browser productivity metrics while respecting your privacy.",
  "permissions": [
    "tabs",
    "idle",
    "storage",
    "alarms",
    "notifications"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": "icons/icon128.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
